# OpenAI (ChatGPT) — solo server-side, nunca expongas la clave en el frontend.
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Puerto del servidor API Express.
PORT=3099

# URL pública de la app (callbacks OAuth, enlaces, etc.).
APP_URL="http://localhost:3000"

# Supabase Auth (solo la anon key en el frontend; service role solo server-side).
VITE_SUPABASE_URL="https://xxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
